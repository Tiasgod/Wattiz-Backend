# ─── Aplicação ───────────────────────────────────────────────
APP_NAME=Wattiz
APP_ENV=development
APP_DEBUG=true
APP_VERSION=1.0.0

# ─── Servidor ────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ─── Banco de Dados ──────────────────────────────────────────
POSTGRES_USER=wattiz
POSTGRES_PASSWORD=wattiz_secret
POSTGRES_DB=wattiz_db
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://wattiz:wattiz_secret@db:5432/wattiz_db

# ─── JWT ─────────────────────────────────────────────────────
SECRET_KEY=TROQUE_ESTA_CHAVE_POR_UMA_ALEATORIA_DE_64_CHARS
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── Ollama / IA Lume ─────────────────────────────────────────
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3
LUME_TEMPERATURE=0.4
LUME_MAX_TOKENS=1024

# ─── Tarifa padrão (R$/kWh) – usuário pode sobrescrever ──────
DEFAULT_TARIFF=0.75

# ─── CORS ────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
